{
  "name": "battleq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:next\" \"npm run dev:server\"",
    "dev:next": "next dev -p 3000",
    "dev:server": "tsx src/server/gameServer.ts",
    "build": "next build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:all": "npm run build && npm run build:server",
    "start": "next start -p 3000",
    "start:server": "node dist/server/gameServer.js",
    "start:all": "concurrently \"npm run start\" \"npm run start:server\"",
    "lint": "next lint"
  },
  "dependencies": {
    "@initia/icons-react": "^2.1.0",
    "@initia/initia.js": "^1.1.0",
    "@initia/interwovenkit-react": "^2.5.1",
    "@initia/utils": "^2.0.0",
    "@metamask/connect-evm": "^0.9.1",
    "@tanstack/react-query": "^5.96.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "viem": "^2.47.10",
    "wagmi": "2.17.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
