{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2019",
    "lib": ["ES2019"],
    "types": ["node"],
    "sourceMap": true
  },
  "include": ["src/server/**/*.ts"],
  "exclude": ["node_modules", ".next", "dist"]
}
