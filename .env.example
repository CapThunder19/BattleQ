# ══════════════════════════════════════════════════════════════
# BattleQ – Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy to .env.local for local dev.
# On Vercel, set in dashboard → Settings → Environment Variables.

# ─── Rollup Chain ─────────────────────────────────────────────
NEXT_PUBLIC_ROLLUP_CHAIN_ID=BattleQ
NEXT_PUBLIC_ROLLUP_CHAIN_NAME=BattleQ Rollup
NEXT_PUBLIC_ROLLUP_EVM_CHAIN_ID=94217
NEXT_PUBLIC_ROLLUP_NATIVE_SYMBOL=INIT

# ─── Rollup Endpoints (Railway) ──────────────────────────────
# After deploying rollup to Railway, paste your service URL here.
NEXT_PUBLIC_ROLLUP_JSON_RPC=https://battleq-production.up.railway.app
NEXT_PUBLIC_ROLLUP_JSON_RPC_WS=wss://battleq-production.up.railway.app
NEXT_PUBLIC_ROLLUP_RPC=https://battleq-production.up.railway.app/rpc
NEXT_PUBLIC_ROLLUP_REST=https://battleq-production.up.railway.app/rest
NEXT_PUBLIC_ROLLUP_GRPC=https://battleq-production.up.railway.app/grpc

# ─── Treasury & House Wallet ─────────────────────────────────
NEXT_PUBLIC_BATTLEQ_TREASURY=0xa0a301021f0F51d90C2eabE4B17BbD436297E1F8
ROLLUP_HOUSE_PRIVATE_KEY=0xYOUR_HOUSE_WALLET_PRIVATE_KEY

# ─── Upstash Redis (required for Vercel) ─────────────────────
UPSTASH_REDIS_REST_URL=https://YOUR_REDIS.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN
ROLLUP_STORE_PREFIX=battleq

# ─── Socket.IO Game Server ───────────────────────────────────
NEXT_PUBLIC_SOCKET_URL=https://battleq-production.up.railway.app
